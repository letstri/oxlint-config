{
  "name": "@letstri/oxlint-config-monorepo",
  "private": true,
  "description": "Monorepo for @letstri/oxlint-config",
  "license": "MIT",
  "author": "Valerii Strilets",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/letstri/oxlint-config.git"
  },
  "type": "module",
  "scripts": {
    "prepare": "husky",
    "build": "pnpm -r run build",
    "dev": "pnpm -r --parallel run dev",
    "check-types": "pnpm -r run check-types",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "check": "run-p lint check-types format:check",
    "publish": "cd packages/oxlint-config && pnpm publish",
    "update": "taze -r -I major"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "npm-run-all2": "^9.0.2",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0",
    "oxlint-tailwindcss": "^1.3.5",
    "taze": "^19.14.1",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@11.11.0"
}
