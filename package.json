{
  "name": "@letstri/oxc-config-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Monorepo for @letstri/oxc-config",
  "license": "MIT",
  "author": "Valerii Strilets",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/letstri/oxc-config.git"
  },
  "type": "module",
  "scripts": {
    "build": "pnpm -r run build",
    "dev": "pnpm -r --parallel run dev",
    "check-types": "tsc --noEmit && pnpm -r run check-types",
    "lint": "oxlint -c oxlint.config.ts",
    "lint:fix": "oxlint -c oxlint.config.ts --fix",
    "format": "oxfmt -c oxfmt.config.ts",
    "format:check": "oxfmt -c oxfmt.config.ts --check",
    "check": "run-p lint check-types format:check",
    "update": "taze -r -I major",
    "prepare": "husky"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "husky": "^9.1.7",
    "npm-run-all2": "^9.0.2",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0",
    "oxlint-tailwindcss": "^1.3.5",
    "taze": "^19.14.1",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@11.11.0"
}
